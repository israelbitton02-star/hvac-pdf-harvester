# ── Supabase ──────────────────────────────────────────────────────────────────
# URL de ton projet Supabase (ex: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé service_role (Settings → API → service_role — ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nom du bucket Storage Supabase
SUPABASE_BUCKET=documents

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées. Utilise * pour tout autoriser (dev), ou l'URL Lovable en prod.
# Ex: https://mon-app.lovable.app,https://mon-domaine.com
ALLOWED_ORIGINS=*

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=8000
